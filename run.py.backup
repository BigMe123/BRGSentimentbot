            "CAN", "ITA", "ESP", "KOR", "MEX", "IDN", "TUR", "NLD", "SAU", "CHE"
        ]

        country = Prompt.ask(
            "Country to analyze",
            choices=country_codes,
            default="USA"
        )

        cmd = ["python", "-c", f"""
import sys
sys.path.append('.')
try:
    from sentiment_bot.gpi_v2 import GPIv2
    print('🔄 Calculating GPI v2 for {country}...')
    gpi = GPIv2()
