try:
    from sentiment_bot.gpi_rss import GPIRss
    print('📡 Calculating RSS-based GPI for {country}...')
    gpi = GPIRss()
    result = gpi.calculate_gpi('{country}', days_back={days})
    print('\\n📊 RSS GPI Results:')
