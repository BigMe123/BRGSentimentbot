    table.add_row(
        "5", "📊 View Statistics", "SKB catalog stats and source distribution"
    )
    table.add_row("6", "📥 Import SKB Data", "Import sources from YAML files")
    table.add_row("7", "🔧 List Connectors", "Show all available connector types")

    # Quick actions
