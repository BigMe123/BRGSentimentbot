        country_codes = [
            "USA", "CHN", "GBR", "DEU", "FRA", "JPN", "RUS", "IND", "BRA", "AUS",
            "CAN", "ITA", "ESP", "KOR", "MEX", "IDN", "TUR", "NLD", "SAU", "CHE"
        ]

